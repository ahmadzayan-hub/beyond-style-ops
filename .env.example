# Beyond Style Agent — environment variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# Core order verification works without any of these (dry-run mode).

# ── Beyond Style Business WhatsApp Number ────────────────────────────────────
# The number customers receive messages FROM. E.164, no + sign.
BUSINESS_WHATSAPP_NUMBER=971551556991

# ── WhatsApp Business Cloud API (Meta) ───────────────────────────────────────
# HOW TO GET THESE:
# 1. https://developers.facebook.com → My Apps → Create App → Business
# 2. Add "WhatsApp" product to your app
# 3. WhatsApp → API Setup → register 0551556991
# 4. Copy "Phone Number ID" (long numeric ID) → WHATSAPP_PHONE_NUMBER_ID
# 5. Copy access token → WHATSAPP_API_TOKEN
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Owner Escalation ──────────────────────────────────────────────────────────
# Owner's personal WhatsApp for High Risk / Needs Correction alerts.
OWNER_WHATSAPP_NUMBER=

# ── Google Sheets ─────────────────────────────────────────────────────────────
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Optional ──────────────────────────────────────────────────────────────────
# Force dry-run even when API credentials are present.
DRY_RUN=
