# Copy this file to .streamlit/secrets.toml  (never commit secrets.toml)
# On Streamlit Community Cloud: paste these into App Settings → Secrets.

GOOGLE_SHEETS_ID = "1OqHh1duQuVyMfLBprV6iUUZMG6NC_5J_tV9eiDNqD5k"

# Google OAuth credentials — each field on its own line (do NOT embed JSON).
# Get these values from your beyond-style-token.json file.
[google_oauth]
token         = ""
refresh_token = "your-refresh-token-here"
token_uri     = "https://oauth2.googleapis.com/token"
client_id     = "your-client-id.apps.googleusercontent.com"
client_secret = "your-client-secret"
scopes        = "https://www.googleapis.com/auth/spreadsheets"

SMTP_HOST       = "smtp.gmail.com"
SMTP_PORT       = "587"
SMTP_USERNAME   = "info@beyondstyle.ae"
SMTP_PASSWORD   = "your-app-password"
ALERT_EMAIL     = "info@beyondstyle.ae"

WHATSAPP_PHASE2_ENABLED      = "false"
WHATSAPP_PHONE_NUMBER_ID     = "569639416237318"
BUSINESS_WHATSAPP_NUMBER     = "971551556991"
OWNER_WHATSAPP_NUMBER        = ""
